<Page x:Class="Main.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Main.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
        <StackPanel>
            <TextBlock Text="Профиль" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>
            <TextBlock Margin="0,0,0,4"><Run Text="Никнейм: " FontWeight="Bold"/><Run Text="{Binding User.Nickname, Mode=OneWay}"/></TextBlock>
            <TextBlock Margin="0,0,0,4"><Run Text="Логин: " FontWeight="Bold"/><Run Text="{Binding User.Login, Mode=OneWay}"/></TextBlock>
            <TextBlock Margin="0,0,0,4"><Run Text="Email: " FontWeight="Bold"/><Run Text="{Binding User.Email, Mode=OneWay}"/></TextBlock>
            <TextBlock Margin="0,0,0,4"><Run Text="Роль: " FontWeight="Bold"/><Run Text="{Binding RoleName, Mode=OneWay}"/></TextBlock>
            <TextBlock Margin="0,0,0,16"><Run Text="Дата регистрации: " FontWeight="Bold"/><Run Text="{Binding User.Registration, Mode=OneWay, StringFormat=dd.MM.yyyy}"/></TextBlock>

            <StackPanel Margin="0,0,0,16">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFrozen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Border Background="#FFEEEE" BorderBrush="#FFAAAA" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <TextBlock Text="⚠ Ваш аккаунт заморожен" Foreground="Red" FontWeight="Bold"/>
                </Border>
                <Button Content="Оспорить заморозку" HorizontalAlignment="Left" Command="{Binding AppealFreezeCommand}"/>
            </StackPanel>

            <Button Content="Подать заявку на роль Автора" HorizontalAlignment="Left" Margin="0,0,0,16" Command="{Binding ApplyForAuthorCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanApplyForAuthor}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <TextBlock Text="Мои отзывы" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding Reviews}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Book.BookName}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Rating, StringFormat='★ {0}/10'}" Foreground="#E8A020"/>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
