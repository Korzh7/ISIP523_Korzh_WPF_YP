<UserControl x:Class="Main.Views.AuthorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
        <StackPanel>
            <TextBlock Text="Страница автора" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

            <Button Content="Добавить книгу" HorizontalAlignment="Left" Margin="0,0,0,16"
                    Command="{Binding ShowAddCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowAddForm}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel Margin="0,0,0,16">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowAddForm}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="Название" Margin="0,0,0,4"/>
                <TextBox Text="{Binding BookName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

                <TextBlock Text="Описание" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>

                <TextBlock Text="URL обложки" Margin="0,0,0,4"/>
                <TextBox Text="{Binding ImageUrl, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

                <TextBlock Text="Текст книги" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                         Height="120" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Сохранить" Margin="0,0,8,0"
                            Command="{Binding SaveBookCommand}"/>
                    <Button Content="Отмена"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Мои книги" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding Books}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Margin="8" Padding="8"
                                BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <StackPanel>
                                <Image Source="{Binding ImageURL}" Height="200" Stretch="UniformToFill"/>
                                <TextBlock Text="{Binding BookName}" FontWeight="Bold"
                                           TextWrapping="Wrap" Margin="0,6,0,2"/>
                                <TextBlock Text="{Binding AverageRatingText}"
                                           Foreground="#E8A020" FontSize="11"/>
                                <Button Content="Редактировать" Margin="0,6,0,0"
                                        Command="{Binding DataContext.EditBookCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Замороженные книги" FontSize="16" FontWeight="Bold" Margin="0,16,0,8"/>
            <ItemsControl ItemsSource="{Binding FrozenBooks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Margin="8" Padding="8"
                                BorderBrush="#FFAAAA" BorderThickness="1" CornerRadius="4">
                            <StackPanel>
                                <Image Source="{Binding ImageURL}" Height="200" Stretch="UniformToFill"/>
                                <TextBlock Text="{Binding BookName}" FontWeight="Bold"
                                           TextWrapping="Wrap" Margin="0,6,0,2"/>
                                <Button Content="Оспорить заморозку" Margin="0,6,0,0"
                                        Command="{Binding DataContext.AppealFreezeCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>