<UserControl x:Class="Main.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                     Width="200" Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     Height="32"/>
            <ComboBox ItemsSource="{Binding Genres}"
                      SelectedItem="{Binding SelectedGenre}"
                      DisplayMemberPath="GenreName"
                      Width="150" Margin="0,0,8,0" Height="32"/>
            <Button Content="Сбросить жанр" Height="32" Margin="0,0,8,0"
                    Command="{Binding ResetGenreCommand}"/>
            <ComboBox ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SortBy}"
                      Width="120" Height="32"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Books}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Margin="8" Padding="8"
                                BorderBrush="#CCCCCC" BorderThickness="1"
                                CornerRadius="4" Cursor="Hand">
                            <StackPanel>
                                <Image Source="{Binding ImageURL}" Height="200"
                                       Stretch="UniformToFill"/>
                                <TextBlock Text="{Binding BookName}" FontWeight="Bold"
                                           TextWrapping="Wrap" Margin="0,6,0,2"/>
                                <TextBlock Text="{Binding User.Nickname}" Foreground="Gray"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding AverageRatingText}"
                                           Foreground="#E8A020" FontSize="11"/>
                                <Button Content="Открыть" Margin="0,6,0,0"
                                        Command="{Binding DataContext.OpenBookCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="+ В список" Margin="0,4,0,0"
                                        Command="{Binding DataContext.AddToListCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>