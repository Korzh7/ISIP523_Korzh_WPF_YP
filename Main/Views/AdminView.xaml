<UserControl x:Class="Main.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Жалобы" Style="{StaticResource TabButton}"
                    Command="{Binding SwitchTabCommand}" CommandParameter="Complaints"/>
            <Button Content="Разморозка" Style="{StaticResource TabButton}"
                    Command="{Binding SwitchTabCommand}" CommandParameter="Unfreeze"/>
            <Button Content="Заявки на автора" Style="{StaticResource TabButton}"
                    Command="{Binding SwitchTabCommand}" CommandParameter="RoleApps"/>
            <Button Content="Замороженные" Style="{StaticResource TabButton}"
                    Command="{Binding SwitchTabCommand}" CommandParameter="Frozen"/>
            <Button Content="Пользователи" Style="{StaticResource TabButton}"
                    Command="{Binding SwitchTabCommand}" CommandParameter="Users"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding Complaints}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTab}" Value="Complaints">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock>
                                        <Run Text="От: " FontWeight="Bold"/>
                                        <Run Text="{Binding User.Nickname, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="На книгу: " FontWeight="Bold"/>
                                        <Run Text="{Binding Book.BookName, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="На автора: " FontWeight="Bold"/>
                                        <Run Text="{Binding TargetAuthor.Nickname, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Причина: " FontWeight="Bold"/>
                                        <Run Text="{Binding Reason, Mode=OneWay}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="Принять" Margin="0,0,8,0"
                                                Command="{Binding DataContext.AcceptComplaintCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Отклонить"
                                                Command="{Binding DataContext.RejectComplaintCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding UnfreezeApplications}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTab}" Value="Unfreeze">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock>
                                        <Run Text="Пользователь: " FontWeight="Bold"/>
                                        <Run Text="{Binding User.Nickname, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Тип: " FontWeight="Bold"/>
                                        <Run Text="{Binding TargetType, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Книга: " FontWeight="Bold"/>
                                        <Run Text="{Binding TargetBook.BookName, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Причина: " FontWeight="Bold"/>
                                        <Run Text="{Binding Reason, Mode=OneWay}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="Принять" Margin="0,0,8,0"
                                                Command="{Binding DataContext.AcceptUnfreezeCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Отклонить"
                                                Command="{Binding DataContext.RejectUnfreezeCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding RoleApplications}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTab}" Value="RoleApps">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock>
                                        <Run Text="Пользователь: " FontWeight="Bold"/>
                                        <Run Text="{Binding User.Nickname, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Дата: " FontWeight="Bold"/>
                                        <Run Text="{Binding ApplicationDate, Mode=OneWay, StringFormat=dd.MM.yyyy}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="Принять" Margin="0,0,8,0"
                                                Command="{Binding DataContext.AcceptRoleApplicationCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Отклонить"
                                                Command="{Binding DataContext.RejectRoleApplicationCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTab}" Value="Frozen">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Замороженные книги" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding FrozenBooks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FFAAAA" BorderThickness="1"
                                        CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding BookName}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Замороженные пользователи" FontWeight="Bold" Margin="0,8,0,8"/>
                    <ItemsControl ItemsSource="{Binding FrozenUsers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FFAAAA" BorderThickness="1"
                                        CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Nickname}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Замороженные отзывы" FontWeight="Bold" Margin="0,8,0,8"/>
                    <ItemsControl ItemsSource="{Binding FrozenReviews}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FFAAAA" BorderThickness="1"
                                        CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding User.Nickname}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Users}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTab}" Value="Users">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock>
                                        <Run Text="{Binding Nickname, Mode=OneWay}" FontWeight="Bold"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding Role.RoleName, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Email, Mode=OneWay}" Foreground="Gray"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="Сменить роль" Margin="0,0,8,0"
                                                Command="{Binding DataContext.AssignRoleCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Сменить пароль"
                                                Command="{Binding DataContext.ChangePasswordCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>