<UserControl x:Class="Main.Views.MainPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:vm="clr-namespace:Main.ViewModels">
    <UserControl.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#2D2D2D">

            <Button Command="{Binding NavigateCommand}" CommandParameter="Catalog"
                    Style="{StaticResource SidebarButton}">
                <Button.ToolTip>
                    <ToolTip Content="Каталог книг"/>
                </Button.ToolTip>
                <iconPacks:PackIconMaterial Kind="BookOpenVariant" Width="24" Height="24"/>
            </Button>

            <Button Command="{Binding NavigateCommand}" CommandParameter="Lists"
                    Style="{StaticResource SidebarButton}">
                <Button.ToolTip>
                    <ToolTip Content="Списки книг"/>
                </Button.ToolTip>
                <iconPacks:PackIconMaterial Kind="BookmarkMultiple" Width="24" Height="24"/>
            </Button>

            <Button Command="{Binding NavigateCommand}" CommandParameter="Profile"
                    Style="{StaticResource SidebarButton}">
                <Button.ToolTip>
                    <ToolTip Content="Профиль"/>
                </Button.ToolTip>
                <iconPacks:PackIconMaterial Kind="Account" Width="24" Height="24"/>
            </Button>

            <Button Command="{Binding NavigateCommand}" CommandParameter="Author"
                    Style="{StaticResource SidebarButton}"
                    Visibility="{Binding IsAuthor}">
                <Button.ToolTip>
                    <ToolTip Content="Страница автора"/>
                </Button.ToolTip>
                <iconPacks:PackIconMaterial Kind="Pen" Width="24" Height="24"/>
            </Button>

            <Button Command="{Binding NavigateCommand}" CommandParameter="Admin"
                    Style="{StaticResource SidebarButton}"
                    Visibility="{Binding IsAdmin}">
                <Button.ToolTip>
                    <ToolTip Content="Администрирование"/>
                </Button.ToolTip>
                <iconPacks:PackIconMaterial Kind="ShieldAccount" Width="24" Height="24"/>
            </Button>

            <Button Command="{Binding NavigateCommand}" CommandParameter="Frozen"
                    Style="{StaticResource SidebarButton}"
                    Visibility="{Binding IsFrozen}">
                <Button.ToolTip>
                    <ToolTip Content="Аккаунт заморожен"/>
                </Button.ToolTip>
                <iconPacks:PackIconMaterial Kind="Snowflake" Width="24" Height="24" Foreground="Red"/>
            </Button>

        </StackPanel>

        <ContentControl Grid.Column="1" Content="{Binding CurrentSection}"/>
    </Grid>

    
</UserControl>