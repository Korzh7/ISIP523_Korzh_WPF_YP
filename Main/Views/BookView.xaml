<UserControl x:Class="Main.Views.BookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" HorizontalAlignment="Left" Margin="0,0,0,12"
                Command="{Binding GoBackCommand}">
            <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="20" Height="20"/>
        </Button>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Source="{Binding Book.ImageURL}" Height="280"
                           Stretch="UniformToFill" VerticalAlignment="Top"/>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="{Binding Book.BookName}" FontSize="22" FontWeight="Bold"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock Foreground="Gray" Margin="0,0,0,4">
                            <Run Text="Автор: "/>
                            <Run Text="{Binding Author, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Foreground="Gray" Margin="0,0,0,4">
                            <Run Text="Жанры: "/>
                            <Run Text="{Binding Genres, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Foreground="#E8A020" Margin="0,0,0,12">
                            <Run Text="★ "/>
                            <Run Text="{Binding Book.AverageRatingText, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Book.Description}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Пожаловаться на книгу" Margin="0,0,8,0"
                            Command="{Binding ComplainBookCommand}"/>
                    <Button Content="Пожаловаться на автора" Margin="0,0,8,0"
                            Command="{Binding ComplainAuthorCommand}"/>
                    <Button Content="Заморозить книгу" Command="{Binding FreezeBookCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <TextBlock Text="Текст книги" FontSize="16" FontWeight="Bold" Margin="0,16,0,8"/>
                <TextBlock Text="{Binding Book.Text}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <TextBlock Text="Отзывы" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding Book.Reviews}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding User.Nickname}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Rating, StringFormat='★ {0}/10'}"
                                               Foreground="#E8A020"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Заморозить отзыв" Margin="0,0,8,0"
                                                Command="{Binding DataContext.FreezeReviewCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsAdmin,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Пожаловаться"
                                                Command="{Binding DataContext.ComplainReviewCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Оставить отзыв" FontSize="16" FontWeight="Bold" Margin="0,16,0,8"/>
                <StackPanel>
                    <TextBlock Text="Оценка (1-10)" Margin="0,0,0,4"/>
                    <Slider Minimum="1" Maximum="10" Value="{Binding ReviewRating}"
                            TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ReviewRating}" Margin="0,0,0,8"/>
                    <TextBlock Text="Текст отзыва" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ReviewText, UpdateSourceTrigger=PropertyChanged}"
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>
                    <Button Content="Отправить отзыв" HorizontalAlignment="Left"
                            Command="{Binding AddReviewCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>